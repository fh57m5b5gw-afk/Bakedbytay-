<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>BakedByTay</title>

<style>
body {
  margin: 0;
  font-family: Arial, sans-serif;
  background: black;
  color: white;
}

/* HERO */
.hero {
  height: 60vh;
  background: url('cover.jpg') center/cover no-repeat;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-direction: column;
  text-shadow: 0 0 20px black;
}

.hero h1 {
  font-size: 50px;
  margin: 0;
}

.hero p {
  font-size: 18px;
}

/* SECTION */
.section {
  padding: 40px 20px;
  text-align: center;
}

.grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
  gap: 20px;
}

/* CARD */
.card {
  background: #111;
  border-radius: 15px;
  overflow: hidden;
  box-shadow: 0 0 15px #00cfff33;
}

.card img {
  width: 100%;
  height: 200px;
  object-fit: cover;
}

.card-content {
  padding: 15px;
}

.price {
  color: #00ffcc;
  font-size: 20px;
}

/* INPUT */
input {
  width: 80%;
  padding: 10px;
  border-radius: 10px;
  border: none;
  margin-top: 10px;
}

/* TOTAL */
.total {
  font-size: 24px;
  margin-top: 20px;
  color: #00ffcc;
}

/* BUTTON */
button {
  margin-top: 20px;
  padding: 15px 25px;
  border: none;
  border-radius: 30px;
  background: #00cfff;
  color: white;
  font-size: 18px;
  cursor: pointer;
}

/* FOOTER */
.footer {
  margin-top: 40px;
  padding: 20px;
  font-size: 14px;
  background: #111;
}
</style>
</head>

<body>

<!-- HERO -->
<div class="hero">
  <h1>BakedByTay</h1>
  <p>Luxury Cookies • $3 Each</p>
</div>

<!-- COOKIES -->
<div class="section">
  <h2>Our Cookies</h2>

  <div class="grid">

    <div class="card">
      <img src="cookie1.jpg">
      <div class="card-content">
        <h3>Red Velvet Oreo</h3>
        <div class="price">$3</div>
        <input type="number" id="c1" placeholder="Quantity" oninput="calc()">
      </div>
    </div>

    <div class="card">
      <img src="cookie2.jpg">
      <div class="card-content">
        <h3>Cookies & Cream</h3>
        <div class="price">$3</div>
        <input type="number" id="c2" placeholder="Quantity" oninput="calc()">
      </div>
    </div>

    <div class="card">
      <img src="cookie3.jpg">
      <div class="card-content">
        <h3>Strawberry Crunch</h3>
        <div class="price">$3</div>
        <input type="number" id="c3" placeholder="Quantity" oninput="calc()">
      </div>
    </div>

  </div>

  <div class="total">
    Total: $<span id="total">0</span>
  </div>

  <button onclick="order()">Place Order</button>

</div>

<!-- FOOTER -->
<div class="footer">
  Cash App: $Taywkeyfr<br>
  Preorders Available • Ashley Ridge • Friday Sales
</div>

<script>
function calc() {
  let a = document.getElementById("c1").value || 0;
  let b = document.getElementById("c2").value || 0;
  let c = document.getElementById("c3").value || 0;

  let total = (a*3) + (b*3) + (c*3);
  document.getElementById("total").innerText = total;
}

function order() {
  alert("Send payment via Cash App to confirm order.");
}
</script>

</body>
</html>
